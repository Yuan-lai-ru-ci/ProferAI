# Profer Team Server 环境变量
# 复制为 .env 并修改

# === 必填 ===
JWT_SECRET=change-me-to-a-random-64-byte-hex
ADMIN_PASSWORD=change-me-to-a-strong-password

# === 安全（生产必设）===
# ALLOWED_ORIGIN=https://your-domain.com   # CORS 允许的源；支持多个域名（逗号分隔）。未设置时拒绝浏览器跨域；开发时如确有需要请显式设为 *
# CHANNEL_ENCRYPTION_KEY=                  # 渠道 API Key 加密密钥（COMMERCIAL_MODE=true 时必填，64 位 hex）

# === 可选 ===
# PORT=3456
# ADMIN_EMAIL=admin@proma.local
# MAX_FILE_SIZE=524288000
# MAX_BODY_SIZE=1048576          # JSON 请求体上限，默认 1MB
# PAPERPIPE_MAX_FILE_SIZE=209715200  # Paperpipe PDF 文件上限，默认 200MB
# PAPERPIPE_MAX_BODY_SIZE=210763776  # Paperpipe multipart 实际请求体上限（含 header 余量）
# PAPERPIPE_BRIDGE_URL=http://host.docker.internal:9876
# PAPERPIPE_BRIDGE_SECRET=           # 必须与 Bridge 部署端校验的 X-Paperpipe-Internal-Key 一致
# DATA_DIR=/app/data
# MINERU_API_KEY=                # MinerU v4 API Key，论文知识库解析需要 (https://mineru.net)
