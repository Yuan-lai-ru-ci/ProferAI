# Profer Team Server 环境变量
# 复制为 .env 并修改

# === 必填 ===
JWT_SECRET=change-me-to-a-random-64-byte-hex
ADMIN_PASSWORD=change-me-to-a-strong-password

# === 安全（生产必设）===
# ALLOWED_ORIGIN=https://your-domain.com   # CORS 允许的源；支持多个域名（逗号分隔）。未设置时拒绝浏览器跨域；开发时如确有需要请显式设为 *
# CHANNEL_ENCRYPTION_KEY=                  # 渠道 API Key 加密密钥（COMMERCIAL_MODE=true 时必填，64 位 hex）

# === 可选 ===
# PORT=3456
# ADMIN_EMAIL=admin@proma.local
# MAX_FILE_SIZE=524288000
# MAX_BODY_SIZE=1048576          # JSON 请求体上限，默认 1MB
# === Paperpipe Bridge（生产部署）===
# 当前上传链路会在 Electron 与 Server 各完整缓冲一次 PDF；生产先保守限制为 50MB。
# PAPERPIPE_MAX_FILE_SIZE=52428800
# PAPERPIPE_MAX_BODY_SIZE=53477376   # multipart 文件上限 + 1MB header 余量
# PAPERPIPE_BRIDGE_URL=http://host.docker.internal:9876
# PAPERPIPE_BRIDGE_SECRET=            # 必填；必须与 Bridge 强制校验的 X-Paperpipe-Internal-Key 一致
# 生成密钥：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Bridge 仅监听宿主机私网/loopback，不得直接暴露到公网；Docker Compose 已声明 host-gateway 映射。
# 部署与 E2E 验收步骤见 server/docs/paperpipe-operations.md。
# DATA_DIR=/app/data
# MINERU_API_KEY=                # MinerU v4 API Key，论文知识库解析需要 (https://mineru.net)
